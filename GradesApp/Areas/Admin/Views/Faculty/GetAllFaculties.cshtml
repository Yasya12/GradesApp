@model IEnumerable<ApplicationUser>

<!DOCTYPE html>
<html>
<head>
    <title>Faculty List</title>
</head>
<body>
    <div class="container">
        <div class="row pt-4 pb-4">
            <div class="col-4">
                <h2 class="text-primary">
                    Faculty List
                </h2>
            </div>
            <div class="col-2 text-end">
                <a asp-area="Admin" asp-controller="Faculty" asp-action="Upsert" class="btn btn-primary">
                    <i class="bi bi-plus-lg"></i> Create Faculty
                </a>
            </div>
        </div>
        <ul>
            <ul>
                <ul>
                    @foreach (var item in Model)
                    {
                        <li>
                            <a asp-area="Admin" asp-controller="Faculty" asp-action="Upsert" asp-route-id="@item.Id" class="custom-link">@item.Name</a>
                        </li>
                    }
                </ul>
            </ul>


        </ul>
    </div>
</body>
</html>

<style>
    .custom-link {
        color: black;
        text-decoration: none; 
        transition: color 0.3s; 
    }

    .custom-link:hover {
         color: blue; 
     }
</style>
