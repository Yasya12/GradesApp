@using Grades.Domain.Entities
@model IEnumerable<Specialty>

<!DOCTYPE html>
<html>
<head>
    <title>Faculty List</title>
</head>
<body>
    <div class="container">
        <div class="row pt-4 pb-4">
            <div class="col-4">
                <h2 class="text-primary">
                    Speciality List
                </h2>
            </div>
            <div class="col-2 text-end">
                <a asp-area="Faculty" asp-controller="Home" asp-action="Upsert" class="btn btn-primary">
                    <i class="bi bi-plus-lg"></i> Create Speciality
                </a>
            </div>
        </div>
        <ul>
            <ul>
                <ul>
                    @foreach (var item in Model)
                    {
                        <li>
                            <div class="row">
                                <div class="col-3">
                                    <a asp-area="Faculty" asp-controller="Home" asp-action="Upsert" asp-route-id="@item.Id" class="custom-link">@item.Name</a>
                                </div>
                                <div class="col-3">
                                    <a asp-controller="Home" asp-action="DeleteSpecialty" asp-route-id="@item.Id" class="btn btn-danger border form-control">
                                        Delete
                                    </a>
                                </div>
                            </div>
                        </li>
                    }
                </ul>
            </ul>
        </ul>
    </div>
</body>
</html>

<style>
    .custom-link {
        color: black;
        text-decoration: none; 
        transition: color 0.3s; 
    }

    .custom-link:hover {
         color: blue; 
     }
</style>
