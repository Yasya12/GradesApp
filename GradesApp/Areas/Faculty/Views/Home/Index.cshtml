@using Grades.Domain.Entities
@model IEnumerable<Subject>

<div class="container">
    <div class="row pt-4 pb-4">
        <div class="col-6">
            <h2 class="text-primary">
                Subject List
            </h2>
        </div>
        <div class="col-6 text-end">
            <a asp-area="Faculty" asp-controller="Home" asp-action="Upsert" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Create Subject
            </a>

        </div>
    </div>
    <table id="tblData" class="table table-bordered table-striped" style="width:100%">
        <thead>
            <tr>
                <th>
                    Name
                </th>
                <th>
                    Abreviation
                </th>
                <th>
                    Lecturer
                </th>
                <th>

                </th>
            </tr>
        </thead>
    </table>
</div>

@section Scripts {
    @{
        var randomParam = new Random().Next(10000);
    }
    <script src="~/js/faculty/subject/subject.js?cache=@randomParam"></script>
}
